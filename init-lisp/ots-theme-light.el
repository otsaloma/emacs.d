 `(vertical-border ((t (:foreground "#f2ede0"))))
 `(whitespace-space ((t (:background unspecified :foreground "#ff405a"))))
 `(whitespace-tab ((t (:background unspecified :foreground "#ff405a"))))

 ;; Font-lock
 `(font-lock-builtin-face ((t (:foreground "#ff6f87"))))
 `(font-lock-comment-delimiter-face ((t (:inherit font-lock-comment-face))))
 `(font-lock-comment-face ((t (:foreground "#84a3c2"))))
 `(font-lock-constant-face ((t (:inherit font-lock-type-face))))
 `(font-lock-doc-string-face ((t (:inherit font-lock-comment-face))))
 `(font-lock-function-name-face ((t (:foreground "#1d77ff"))))
 `(font-lock-keyword-face ((t (:foreground "#897fba"))))
 `(font-lock-negation-char-face ((t (:inherit font-lock-function-name-face))))
 `(font-lock-preprocessor-face ((t (:inherit font-lock-function-name-face))))
 `(font-lock-property-use-face ((t (:foreground unspecified))))
 `(font-lock-regexp-grouping-backslash ((t (:inherit font-lock-keyword-face))))
 `(font-lock-regexp-grouping-construct ((t (:inherit font-lock-keyword-face))))
 `(font-lock-string-face ((t (:foreground "#ba7fba"))))
 `(font-lock-type-face ((t (:foreground "#00bb29"))))
 `(font-lock-variable-name-face ((t (:foreground "#b0a678"))))
 `(font-lock-warning-face ((t (:foreground "#ff405a"))))

 ;; Add-on packages
 `(copilot-overlay-face ((t (:foreground "#ff5555"))))
 `(corfu-annotations ((t (:foreground "#666666"))))
 `(corfu-bar ((t (:background unspecified))))
 `(corfu-border ((t (:background unspecified))))
 `(corfu-current ((t (:background "#527bcc" :foreground "#ffffff"))))
 `(corfu-default ((t (:background "#dddddd" :foreground "#666666"))))
 `(cua-rectangle ((t (:background "#f0f0aa" :foreground unspecified))))
