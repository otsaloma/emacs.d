 `(git-gutter:deleted ((t (:background "#ff8888" :foreground "#f2ede0"))))
 `(git-gutter:modified ((t (:background "#8888ff" :foreground "#f2ede0"))))
 `(jinx-misspelled ((t (:underline "#ff6f87"))))
 `(makefile-space ((t (:background "#ffd9b3" :foreground unspecified))))
 `(markdown-code-face ((t (:background unspecified :foreground "#ba7fba"))))
 `(markdown-header-face ((t (:foreground "#1d77ff" :weight bold))))
 `(markdown-inline-code-face ((t (:background unspecified :foreground "#ba7fba"))))
 `(mmm-default-submode-face ((t (:background unspecified :foreground unspecified))))
 `(neo-dir-link-face ((t (:background unspecified :foreground "#84a3c2"))))
 `(neo-file-link-face ((t (:background unspecified :foreground "#999999"))))
 `(neo-root-dir-face ((t (:background unspecified :foreground "#999999"))))
 `(orderless-match-face-0 ((t (:foreground "#ff8888"))))
 `(orderless-match-face-1 ((t (:foreground "#ff8888"))))
 `(orderless-match-face-2 ((t (:foreground "#ff8888"))))
 `(orderless-match-face-3 ((t (:foreground "#ff8888"))))
 `(popup-tip-face ((t (:background "#f0f080" :foreground "#303030"))))
 `(sh-heredoc ((t (:foreground "#ba7fba"))))
 `(sh-quoted-exec ((t (:foreground "#00bb29"))))
 `(tab-line ((t (:background "#f2ede0" :box (:line-width (1 . 10) :color "#f2ede0")))))
 `(tab-line-tab ((t (:inherit tab-line))))
 `(tab-line-tab-current ((t (:inherit tab-line :foreground "#111111"))))
 `(tab-line-tab-inactive ((t (:inherit tab-line :foreground "#999999"))))
 `(tab-line-tab-modified ((t (:foreground "#ff405a"))))
 `(tab-line-highlight ((t (:inherit tab-line-tab-current))))
 `(vertico-current ((t (:background "#f5f5aa" :foreground unspecified))))
 `(vertico-group-title ((t (:foreground "#1d77ff"))))
 `(vterm-color-black ((t (:foreground "#252525"))))
 `(vterm-color-blue ((t (:foreground "#3465a4"))))
 `(vterm-color-cyan ((t (:foreground "#06989a"))))
 `(vterm-color-green ((t (:foreground "#4e9a06"))))
 `(vterm-color-magenta ((t (:foreground "#75507b"))))
 `(vterm-color-red ((t (:foreground "#cc0000"))))
 `(vterm-color-white ((t (:foreground "#eeeeec"))))
 `(vterm-color-yellow ((t (:foreground "#c4a000"))))
 `(woman-bold ((t (:foreground "#1d77ff"))))
 `(woman-italic ((t (:foreground "#9f6fff"))))

 )

(provide-theme 'ots-light)
(provide 'ots-theme-light)
